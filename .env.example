# Nome do sistema (prefixo nas mensagens Telegram e comandos, ex.: /ahgora_desativar)
SISTEMA_PONTO=Ahgora

# Credenciais (e-mail e senha Microsoft — usados no SSO)
AHGORA_USER=seu.email@empresa.com.br
AHGORA_PASS=sua_senha_microsoft

# Segredo TOTP para MFA Microsoft (chave base32 do seu autenticador)
# Se não usa MFA, deixe em branco
AHGORA_MFA_SECRET=

# URL de login do Ahgora (página inicial que redireciona para o SSO)
# Normalmente é a URL da empresa, ex.: https://app.ahgora.com.br/login ou customizada
AHGORA_LOGIN_URL=https://app.ahgora.com.br/login

# URL da página de batida de ponto (com o device ID da empresa)
AHGORA_PONTO_URL=https://app.ahgora.com.br/novabatidaonline/?defaultDevice=a935336

# Telegram (notificações e comandos)
# 1. Fale com @BotFather no Telegram → /newbot → copie o token
# 2. Fale com @userinfobot → copie seu Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Gist (persistência de datas desativadas)
# 1. Crie um token em github.com/settings/tokens/new (scope: gist)
# 2. Crie um Gist secreto em gist.github.com com arquivo app-ahgora-disabled-dates.json contendo []
GH_GIST_TOKEN=
GIST_ID=

# Configuração do Puppeteer
# HEADLESS=false   # descomente para ver o browser
# DEBUG=true       # descomente para screenshots + browser aberto + log detalhado
# DRY_RUN=false    # descomente para simular ações sem clicar

# Chromium do sistema (necessário em servidores Linux sem o bundled do Puppeteer)
# Em DigitalOcean/VPS: PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Local/GitHub Actions: deixe em branco (usa o Chromium do Puppeteer)
# PUPPETEER_EXECUTABLE_PATH=

# Geolocalização (coordenadas do escritório para o Ahgora aceitar o ponto)
# Pegue no Google Maps: botão direito → copie as coordenadas
GEO_LAT=-3.054679
GEO_LNG=-60.032772
